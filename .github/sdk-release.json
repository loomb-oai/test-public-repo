{
  "repositories": {
    "private": "loomb-oai/test-private-repo",
    "public": "loomb-oai/test-public-repo",
    "strategy": "mirror"
  },
  "schedules": {
    "nightly-beta": {
      "operation": "beta",
      "cron": "0 18 * * *",
      "timezone": "America/Los_Angeles"
    },
    "weekly-rc": {
      "operation": "cut-rc",
      "cron": "1 0 * * 1",
      "timezone": "America/Los_Angeles"
    }
  },
  "channels": {
    "alpha": {
      "sourceBranch": "main",
      "tagPattern": "v{version}-alpha.{date}.{sequence}",
      "npmDistTag": "alpha",
      "pypiPhase": "alpha"
    },
    "beta": {
      "sourceBranch": "main",
      "tagPattern": "v{version}-beta.{date}",
      "npmDistTag": "beta",
      "pypiPhase": "beta",
      "onlyIfChanged": true
    },
    "rc": {
      "sourceBranch": "main",
      "branchPattern": "rc/{version}",
      "tagPattern": "v{version}-rc.{iteration}",
      "npmDistTag": "rc",
      "pypiPhase": "rc"
    },
    "production": {
      "sourceBranchPattern": "rc/{version}",
      "tagPattern": "v{version}",
      "npmDistTag": "latest",
      "pypiPhase": "final"
    }
  },
  "publishing": {
    "mode": "simulate",
    "trustedPublisherSurface": "public-mirror",
    "npm": {
      "strategy": "trusted-publisher",
      "workflowFile": "release-bot.yml",
      "requires": [
        "GitHub-hosted runner",
        "Node >= 22.14.0",
        "npm >= 11.5.1",
        "permissions.id-token: write",
        "package repository.url exactly matches the public GitHub repository configured in npm"
      ]
    },
    "pypi": {
      "strategy": "trusted-publisher",
      "workflowFile": "release-bot.yml",
      "requires": [
        "permissions.id-token: write",
        "PyPI Trusted Publisher configured for the repository/workflow/environment"
      ],
      "recommendedAction": "pypa/gh-action-pypi-publish@release/v1"
    }
  },
  "packages": {
    "npm": {
      "id": "node-sdk",
      "path": "packages/node-sdk",
      "packageName": "@demo/node-sdk"
    },
    "pypi": {
      "id": "python-sdk",
      "path": "packages/python-sdk",
      "packageName": "demo-python-sdk"
    }
  }
}
